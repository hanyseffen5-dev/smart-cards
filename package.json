{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "pnpm --parallel --filter @workspace/api-server --filter @workspace/smart-flashcards run dev",
    "dev:mobile": "pnpm --parallel --filter @workspace/api-server --filter @workspace/smart-flashcards run dev:mobile",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/smart-flashcards run dev",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:reset": "node ./scripts/reset-embedded-db.mjs",
    "db:restore-misc": "node ./scripts/restore-misc-lesson.mjs",
    "db:fill-misc-translations": "node ./scripts/fill-misc-example-translations.mjs",
    "db:restore-daniel": "node ./scripts/restore-daniel-images.mjs",
    "db:restore-all": "node ./scripts/restore-all-lessons.mjs",
    "db:snapshot-curriculum": "node ./scripts/snapshot-curriculum-lessons.mjs",
    "db:audit-curriculum": "node ./scripts/audit-curriculum-lessons.mjs",
    "words:sync": "node ./scripts/export-app-words.mjs",
    "words:export": "node ./scripts/export-app-words.mjs --full",
    "db:apply-daniel-batch2": "node ./scripts/apply-daniel-batch2.mjs",
    "db:apply-daniel-batch3": "node ./scripts/apply-daniel-batch3.mjs",
    "db:apply-daniel-batch5": "node ./scripts/apply-daniel-batch5.mjs",
    "db:seed-grade1": "node ./scripts/seed-grade1-lesson.mjs",
    "db:seed-grade2": "node ./scripts/seed-grade2-lesson.mjs",
    "db:sync-grade2": "node ./scripts/seed-grade2-lesson.mjs --sync",
    "db:seed-grade3": "node ./scripts/seed-grade3-lesson.mjs",
    "db:sync-grade3": "node ./scripts/seed-grade3-lesson.mjs --sync",
    "db:seed-grade4": "node ./scripts/seed-grade4-lesson.mjs",
    "db:sync-grade4": "node ./scripts/seed-grade4-lesson.mjs --sync",
    "db:seed-grade5": "node ./scripts/seed-grade5-lesson.mjs",
    "db:sync-grade5": "node ./scripts/seed-grade5-lesson.mjs --sync",
    "db:apply-grade3-batch": "node ./scripts/apply-grade3-batch.mjs",
    "db:retarget-grade2": "node ./scripts/retarget-grade2-level.mjs && node ./scripts/seed-grade2-lesson.mjs --sync",
    "images:grade1-generate": "node ./scripts/generate-grade1-images.mjs",
    "db:apply-grade1-batch": "node ./scripts/apply-grade1-batch.mjs",
    "db:apply-grade2-batch": "node ./scripts/apply-grade2-batch.mjs",
    "images:daniel-next": "node ./scripts/list-daniel-words-without-images.mjs 50",
    "images:daniel-scaffold": "node ./scripts/scaffold-daniel-prompts.mjs",
    "images:daniel-generate": "node ./scripts/generate-daniel-images.mjs",
    "images:daniel-apply-word": "node ./scripts/apply-daniel-word.mjs",
    "images:daniel-redo": "node ./scripts/generate-daniel-images.mjs --force redo-v2 && node ./scripts/apply-daniel-redo.mjs",
    "images:daniel-redo-v2": "node ./scripts/generate-daniel-images.mjs --force redo-v2 && node ./scripts/apply-daniel-redo.mjs",
    "images:daniel-redo-chunk": "node ./scripts/generate-daniel-images.mjs --force --offset=0 --limit=5 redo && node ./scripts/apply-daniel-redo.mjs",
    "db:apply-daniel-redo": "node ./scripts/apply-daniel-redo.mjs",
    "images:regenerate": "node ./scripts/regenerate-all-images.mjs",
    "images:clear-lesson": "node ./scripts/clear-lesson-images.mjs",
    "migrate:images": "node ./scripts/migrate-images-to-files.mjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:prod": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/smart-flashcards run build",
    "start:prod": "node ./scripts/start-prod.mjs",
    "sync:drive-backup": "node ./scripts/apply-drive-backup.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "sharp": "^0.34.2",
    "typescript": "~5.9.2"
  }
}
