# ─── Required ───────────────────────────────────────────────────────────────
# Google Gemini API key (text analysis, OCR, translations — example sentences use MyMemory fallback if quota is full)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash-lite
# Model for pronunciation speech-to-text (needs audio support)
GEMINI_STT_MODEL=gemini-2.5-flash

# Local dev without PostgreSQL install:
DATABASE_URL=embedded
# Production / local PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/flashcards

# API server port
PORT=3000

# Frontend dev server port (5173 is often used by other projects, e.g. English curriculum)
VITE_DEV_PORT=5174

# Frontend dev: direct API URL (optional; Vite proxy also uses this)
VITE_API_URL=http://127.0.0.1:3000

# Auto-translate example sentences only (never auto-generates images)
BACKGROUND_WORKERS=false

# Set true only when manually testing ONE card image (Pollinations — free)
ALLOW_IMAGE_GENERATION=false

# Optional: override Pollinations URL (must stay on image.pollinations.ai — paid APIs blocked)
# IMAGE_GENERATION_URL=https://image.pollinations.ai/prompt/{prompt}?width={width}&height={height}&nologo=true&model=flux&seed={seed}

# Sync lessons/images from a remote dev server (leave empty to disable)
# DEV_SYNC_URL=
# DEV_SYNC_TOKEN=

# ─── Google Sheets (login log + admin messages) ─────────────────────────────
# Spreadsheet: https://docs.google.com/spreadsheets/d/1PvRPszBX5akZ3o9K4-9-jUlP28WxqMDVr7fNB5OZ3fQ
# Paste the DEPLOYED Web App URL (/exec) — NOT the spreadsheet edit link.
# Script source: scripts/google-apps-script/smart-cards-webhook.gs
# SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
# MESSAGES_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
